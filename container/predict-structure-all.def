# Apptainer definition for predict-structure — all-in-one with all tools
#
# Mirrors the BV-BRC build pattern from:
#   https://github.com/BV-BRC/runtime_build/tree/master/gpu-builds/cuda-12.2-cudnn-8.9.6
#
# Build (requires the base container from BV-BRC runtime_build):
#   apptainer build predict-structure-all.sif predict-structure-all.def
#
# Or from Docker image:
#   apptainer build predict-structure-all.sif \
#     docker://dxkb/predict-structure-all:latest-gpu
#
# Run:
#   apptainer run --nv \
#     --bind /local_databases:/local_databases \
#     predict-structure-all.sif \
#     auto /input/protein.fasta -o /output

Bootstrap: localimage
From: {{base}}

%arguments
    base=
    runtime=
    packages=

%labels
    Author BV-BRC Team
    Description Unified protein structure prediction (Boltz-2, Chai-1, AlphaFold 2, ESMFold)
    CUDA-Version 12.2.2
    CUDNN-Version 8.9.6

%files
    pyproject.toml /app/predict-structure/pyproject.toml
    README.md /app/predict-structure/README.md
    predict_structure /app/predict-structure/predict_structure
    app_specs /app/predict-structure/app_specs
    cwl /app/predict-structure/cwl
    test_data /app/predict-structure/test_data

%environment
    export PATH="/usr/local/bin:/opt/miniforge/bin:/opt/conda-alphafold/bin:/opt/hhsuite/bin:$PATH"
    export PYTHONPATH="/app/alphafold:$PYTHONPATH"
    export CONDA_PLUGINS_AUTO_ACCEPT_TOS="yes"
    export PYTHONNOUSERSITE=1
    export PYTHONUNBUFFERED=1

    # CUDA / cuDNN
    export CUDA_HOME="/usr/local/cuda-12.2"
    export CUDNN_PATH="/usr/lib/x86_64-linux-gnu"
    export CUDNN_VERSION=8.9.6
    export XLA_FLAGS="--xla_gpu_cuda_data_dir=/usr/local/cuda-12.2 --xla_gpu_force_compilation_parallelism=1"
    export XLA_PYTHON_CLIENT_PREALLOCATE=false
    export XLA_PYTHON_CLIENT_MEM_FRACTION=0.90
    export TF_FORCE_GPU_ALLOW_GROWTH=true
    export CUDA_MODULE_LOADING=EAGER

    # Model/database cache — bind-mount /local_databases at runtime
    if [[ -d /local_databases/boltz ]]; then
        export BOLTZ_CACHE=/local_databases/boltz
    fi
    if [[ -d /local_databases/chai ]]; then
        export CHAI_DOWNLOADS_DIR=/local_databases/chai
    fi
    export DISABLE_PANDERA_IMPORT_WARNING=True

%post -c /bin/bash
    set -e
    set -o pipefail

    export DEBIAN_FRONTEND=noninteractive
    export CONDA_PLUGINS_AUTO_ACCEPT_TOS="yes"
    export PYTHONNOUSERSITE=1

    . /opt/miniforge/etc/profile.d/conda.sh

    # ─── Boltz-2 (Python 3.11) ───────────────────────────────────────
    conda create -p /opt/conda-boltz --yes --quiet python=3.11
    conda activate /opt/conda-boltz
    pip install --no-cache-dir 'torch>=2.2' --index-url https://download.pytorch.org/whl/cu121
    pip install --no-cache-dir 'boltz[cuda]'
    conda deactivate

    # ─── Chai-1 (Python 3.10) ────────────────────────────────────────
    conda create -p /opt/conda-chai --yes --quiet python=3.10
    conda activate /opt/conda-chai
    pip install --no-cache-dir 'torch>=2.3.1' --index-url https://download.pytorch.org/whl/cu121
    pip install --no-cache-dir chai-lab
    conda deactivate

    # ─── ESMFold (Python 3.11) ───────────────────────────────────────
    conda create -p /opt/conda-esmfold --yes --quiet python=3.11
    conda activate /opt/conda-esmfold
    pip install --no-cache-dir 'torch>=2.2' --index-url https://download.pytorch.org/whl/cu121
    pip install --no-cache-dir transformers accelerate biopython
    conda deactivate

    # ─── AlphaFold 2 (Python 3.11) ───────────────────────────────────
    # HHsuite
    git clone --branch v3.3.0 --single-branch https://github.com/soedinglab/hh-suite.git /tmp/hh-suite
    mkdir /tmp/hh-suite/build && cd /tmp/hh-suite/build
    cmake -DCMAKE_INSTALL_PREFIX=/opt/hhsuite ..
    make -j$(nproc) && make install
    ln -s /opt/hhsuite/bin/* /usr/bin
    rm -rf /tmp/hh-suite

    conda create -p /opt/conda-alphafold --yes --quiet python=3.11
    conda install -p /opt/conda-alphafold --channel nvidia --yes cuda=12.2.2
    conda install -p /opt/conda-alphafold --channel conda-forge --yes openmm=8.0.0 pdbfixer
    rm -f /opt/conda-alphafold/lib/plugins/libOpenMM*CUDA* \
          /opt/conda-alphafold/lib/plugins/libOpenMM*OpenCL*

    git clone --depth 1 https://github.com/wilke/alphafold.git /app/alphafold
    wget -q -P /app/alphafold/alphafold/common/ \
        https://git.scicore.unibas.ch/schwede/openstructure/-/raw/7102c63615b64735c4941278d92b554ec94415f8/modules/mol/alg/src/stereo_chemical_props.txt

    conda activate /opt/conda-alphafold
    pip install --no-cache-dir -r /app/alphafold/requirements.txt
    pip install --no-cache-dir \
        jax==0.4.26 \
        'jaxlib==0.4.26+cuda12.cudnn89' \
        -f https://storage.googleapis.com/jax-releases/jax_cuda_releases.html
    conda deactivate

    # ─── predict-structure CLI (Python 3.12) ──────────────────────────
    conda create -p /opt/conda-predict --yes --quiet python=3.12
    cd /app/predict-structure
    /opt/conda-predict/bin/pip install --no-cache-dir -e ".[all]"
    ln -sf /opt/conda-predict/bin/predict-structure /usr/local/bin/predict-structure

    # ─── Cleanup ──────────────────────────────────────────────────────
    conda clean --all --force-pkgs-dirs --yes
    pip cache purge 2>/dev/null || true
    apt-get autoremove --yes 2>/dev/null || true
    apt-get clean 2>/dev/null || true
    rm -rf /var/lib/apt/lists/*

    # Create runtime directories
    mkdir -p /input /output /local_databases /cache
    chmod 777 /cache

    ldconfig

%runscript
    exec predict-structure "$@"

%help
    Unified protein structure prediction container.

    Includes Boltz-2, Chai-1, AlphaFold 2, and ESMFold in separate
    conda environments. Uses the predict-structure CLI for dispatch.

    Usage:
      apptainer run --nv --bind /local_databases:/local_databases \
        predict-structure-all.sif auto input.fasta -o output/

      apptainer run --nv --bind /local_databases:/local_databases \
        predict-structure-all.sif boltz input.fasta -o output/ --use-msa-server

    Tools:
      auto       Auto-discover best available tool
      boltz      Boltz-2 (diffusion, proteins/DNA/RNA/ligands)
      chai       Chai-1 (diffusion, proteins)
      alphafold  AlphaFold 2 (MSA-based, requires databases)
      esmfold    ESMFold (single-sequence, CPU-capable)

    Databases:
      Bind-mount /local_databases with tool model caches:
        /local_databases/boltz/    Boltz model weights
        /local_databases/chai/     Chai model weights
        /local_databases/alphafold/ AlphaFold genetic databases (~2TB)
